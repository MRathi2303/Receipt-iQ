# =========================================================
#  ReceiptIQ — Environment Variables
#  Copy this file to .env and fill in every value marked ⚠️
#  NEVER commit .env to git — add it to .gitignore
# =========================================================

# ── SERVER ──────────────────────────────────────────────
PORT=4000

# ⚠️  HIGHLIGHT: Your deployed frontend URL (for CORS)
FRONTEND_URL=https://YOUR_FRONTEND_DOMAIN.com

# ⚠️  HIGHLIGHT: A strong random string — use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=YOUR_STRONG_RANDOM_API_KEY


# ── AWS CREDENTIALS (local dev only) ────────────────────
# In production, use an IAM Role attached to your EC2/ECS/Lambda — do NOT put keys here
# ⚠️  HIGHLIGHT: Create an IAM user with S3+DynamoDB+SNS+Textract permissions
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# ⚠️  HIGHLIGHT: Your AWS region (e.g. us-east-1, eu-west-1, ap-south-1)
AWS_REGION=us-east-1


# ── S3 ────────────────────────────────────────────────────
# ⚠️  HIGHLIGHT: Create an S3 bucket in AWS console and paste the name here
S3_BUCKET_NAME=your-receiptiq-bucket-name


# ── DYNAMODB ─────────────────────────────────────────────
# ⚠️  HIGHLIGHT: Create a DynamoDB table with primary key: docId (String)
DYNAMODB_TABLE_NAME=receiptiq-receipts


# ── SNS ───────────────────────────────────────────────────
# ⚠️  HIGHLIGHT: Create an SNS topic and paste the ARN here
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_12_DIGIT_ACCOUNT_ID:receiptiq-notifications


# ── SES ───────────────────────────────────────────────────
# ⚠️  HIGHLIGHT: Verify this email address in AWS SES console
SES_FROM_EMAIL=noreply@yourdomain.com


# ── LAMBDA ───────────────────────────────────────────────
# These are set in the Lambda console environment variables, not here.
# (Same keys as above — copy them there too)
