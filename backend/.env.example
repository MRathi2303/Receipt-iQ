# =========================================================
#  ReceiptIQ — Environment Variables
#  Copy this file to .env and fill in the values when you are ready
#  NEVER commit .env to git — add it to .gitignore
# =========================================================

# ── SERVER ──────────────────────────────────────────────
PORT=4000

# Local frontend URL used by the Express server
FRONTEND_URL=http://localhost:4000

# A strong random string shared by frontend and backend
API_KEY=YOUR_STRONG_RANDOM_API_KEY

# A strong random string used to sign login tokens
JWT_SECRET=YOUR_STRONG_JWT_SECRET


# ── AWS CREDENTIALS ──────────────────────────────────────
# Fill these only when you want live AWS processing.
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Example: ap-south-1
AWS_REGION=us-east-1


# ── S3 ────────────────────────────────────────────────────
# Receipt uploads bucket name
S3_BUCKET_NAME=your-receiptiq-bucket-name


# ── DYNAMODB ─────────────────────────────────────────────
# DynamoDB table with primary key: docId (String)
DYNAMODB_TABLE_NAME=receiptiq-receipts


# ── SES ───────────────────────────────────────────────────
# Verified sender email for SES
SES_FROM_EMAIL=noreply@yourdomain.com

# Optional prefix for per-user SNS topics created on signup
SNS_TOPIC_PREFIX=receiptiq-user

# ── GEMINI API ────────────────────────────────────────────
# Create a free API key in Google AI Studio / Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash


# You can leave the AWS values empty until you are ready to connect the live pipeline.
