{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReceiptBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:PutObject",
        "s3:GetObject",
        "s3:HeadObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::receiptiq-uploads-259030234749-ap-south-1",
        "arn:aws:s3:::receiptiq-uploads-259030234749-ap-south-1/*"
      ]
    },
    {
      "Sid": "DynamoDBReceiptsAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem",
        "dynamodb:Scan",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-south-1:259030234749:table/receiptiq-receipts",
        "arn:aws:dynamodb:ap-south-1:259030234749:table/receiptiq-receipts/index/*"
      ]
    },
    {
      "Sid": "DynamoDBUsersAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:ap-south-1:259030234749:table/receiptiq-users",
        "arn:aws:dynamodb:ap-south-1:259030234749:table/receiptiq-users/index/*"
      ]
    },
    {
      "Sid": "SNSUserTopicAccess",
      "Effect": "Allow",
      "Action": [
        "sns:CreateTopic",
        "sns:Subscribe",
        "sns:GetSubscriptionAttributes",
        "sns:ListSubscriptionsByTopic"
      ],
      "Resource": "arn:aws:sns:ap-south-1:259030234749:receiptiq-user-*"
    }
  ]
}
